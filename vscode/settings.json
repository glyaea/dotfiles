{
	"chat.commandCenter.enabled": false,
	"editor.detectIndentation": true,
	"editor.fontFamily": "SF Mono",
	"editor.fontSize": 15,
	"editor.formatOnPaste": false,
	"editor.formatOnSave": false,
	"editor.formatOnType": false,
	"editor.guides.highlightActiveIndentation": false,
	"editor.guides.indentation": false,
	"editor.indentSize": 2,
	"editor.insertSpaces": false,
	"editor.minimap.enabled": false,
	"editor.occurrencesHighlight": "off",
	"editor.stickyScroll.enabled": false,
	"editor.tabSize": 4,
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"explorer.confirmDelete": false,
	"explorer.confirmPasteNative": false,
	"extensions.ignoreRecommendations": true,
	"files.exclude": {"**/*.aux": true, "**/*.bbl": true, "**/*.bcf": true, "**/*.blg": true, "**/*.fdb_latexmk": true, "**/*.fls": true, "**/*.log": true, "**/*.out": true, "**/*.run.xml": true, "**/*.synctex.gz": true, "**/*.toc": true},
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"github.copilot.enable": { "*": false },
	"html.autoClosingTags": false,
	"latex-workshop.formatting.latex": "none",
	// "latex-workshop.latex.tools": [{ "args": ["-lualatex", "-synctex=1", "-interaction=nonstopmode", "-file-line-error", "%DOC%"], "command": "latexmk", "name": "latexmk" }],
	"latex-workshop.view.pdf.toolbar.hide.timeout": 0,
	"python.createEnvironment.trigger": "off",
	"python.terminal.activateEnvironment": false,
	"terminal.external.osxExec": "Alacritty.app",
	"terminal.integrated.fontSize": 13,
	"terminal.integrated.inheritEnv": false,
	"update.mode": "manual",
	"update.showReleaseNotes": false,
	"window.commandCenter": false,
	"workbench.colorCustomizations": {
		"editorBracketMatch.background": "#00000000",
		"editorBracketMatch.border": "#00000016",
		"editor.lineHighlightBorder": "#00000000",
	},
	"workbench.colorTheme": "GitHub Light Default",
	"workbench.editor.editorActionsLocation": "hidden",
	"workbench.editor.empty.hint": "hidden",
	"workbench.layoutControl.enabled": false,
	"workbench.startupEditor": "none",
	"workbench.tree.renderIndentGuides": "none",
}
